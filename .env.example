# ─────────────────────────────────────────────────────────────────────
# Kalshi Trading Bot — Dashboard environment template
# Copy to .env.local and fill in real values. NEVER commit .env.local.
# In Netlify, set these under Site settings → Environment variables.
# ─────────────────────────────────────────────────────────────────────

# Clerk (authentication) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Encryption key for stored Kalshi/GitHub credentials (AES-256-GCM).
# Use a long random string. Rotating it invalidates previously saved creds.
ENCRYPTION_KEY=
